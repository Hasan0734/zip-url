<!DOCTYPE html>
<html>

<head>
    <title>Expired url</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link href="/css/style.css" rel="stylesheet">
</head>

<body class="bg-background selection:bg-primary/30 selection:text-primary scroll-smooth">
    <div class="relative flex w-full min-h-screen items-center justify-center overflow-hidden py-10">


        <div class="fixed inset-0 z-0">
            <div class="absolute top-[-10%] left-[-10%] h-[50%] w-[50%] rounded-full bg-primary/10 blur-[120px]"></div>
            <div class="absolute right-[-10%] bottom-[-10%] h-[40%] w-[40%] rounded-full bg-primary/5 blur-[100px]">
            </div>
            <div class="absolute top-1/2 left-1/2 h-full w-full -translate-x-1/2 -translate-y-1/2 opacity-20" style="
        background-image: radial-gradient(#69f6b8 0.5px, transparent 0.5px); background-size:32px 32px;"></div>
        </div>

        <div class="glass-card emerald-glow w-full max-w-122 rounded-[2rem] bg-background! p-10 md:p-12 text-center">

            <div class="inline-flex items-center justify-center w-16 h-16 bg-red-600/20 rounded-full mb-6">
                <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>

            <h1 class="text-2xl font-bold text-white mb-3">Link Expired</h1>
            <p class="text-muted-foreground mb-8">
                Sorry, this security link has expired for your protection. Please request a new one to continue.
            </p>

            <div class="space-y-3">
                <button
                    class="w-full bg-primary hover:bg-primary/80 text-white font-semibold py-3 rounded-lg transition duration-200">
                    Resend Access Link
                </button>
                <a href="/" class="block text-sm text-muted-foreground hover:text-foreground transition">
                    Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</body>

</html>