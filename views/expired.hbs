<!DOCTYPE html>
<html>

<head>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 flex items-center justify-center h-screen">
    <div class="max-w-md w-full bg-gray-800 p-8 rounded-2xl shadow-xl text-center">
       
        <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-600/20 rounded-full mb-6">
            <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>

        <h1 class="text-2xl font-bold text-white mb-3">Link Expired</h1>
        <p class="text-slate-500 mb-8">
            Sorry, this security link has expired for your protection. Please request a new one to continue.
        </p>

        <div class="space-y-3">
            <button
                class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-lg transition duration-200">
                Resend Access Link
            </button>
            <a href="/" class="block text-sm text-gray-500 hover:text-gray-800 transition">
                Back to Dashboard
            </a>
        </div>
    </div>

</body>

</html>