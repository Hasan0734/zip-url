<!DOCTYPE html>
<html>

<head>
  <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gray-100 flex items-center justify-center h-screen">
  <div class="w-[300px] bg-white rounded-lg p-4">
    <h2 class="text-base/7 font-semibold text-gray-800">ZIP Url</h2>
    <p class="mt-1 text-sm/6 text-gray-400">This link is password protected!
    </p>
    <form class="" id="passwordForm">
      <div>
        <label for="password" class="block text-sm/6 font-medium text-gray-800">Enter Password</label>
        <div class="mt-1 w-full">
          <input id="password" type="password" name="password"
            class="block w-full rounded-md bg-gray-600/5 px-3 py-1.5 text-base text-gray-800 outline-1 -outline-offset-1 outline-gray-400/10 placeholder:text-gray-500 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-500 sm:text-sm/6" />
        </div>
        <div id="message">

        </div>
      </div>
      <button id="submitBtn" type="submit"
        class="mt-2 rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">Submit</button>
    </form>
  </div>

  <script>
    const passwordForm = document.getElementById("passwordForm");
    const input = document.getElementById("password");
    const messageBox = document.getElementById("message");
    const submitBtn = document.getElementById("submitBtn");

    const short_code = window.location.pathname.split('/').filter(Boolean).pop();

    passwordForm.addEventListener('submit', submitPassword)

    async function submitPassword(e) {
      e.preventDefault();
      const password = input.value;

      messageBox.innerHTML = "";
      if (!password) {
        showMessage("Password is required!", "text-red-500");
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "Verifying...";

      try {

        const res = await fetch(`/urls/verify/${short_code}`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ password })
        })

        const json = await res.json();

        console.log(json)
        if (json.status === 'failed') {
          showMessage(json.message || "Invalid password", "text-red-500");
        } else if (json.status === "success") {
          showMessage("Redirecting...", "text-green-500");
          window.location.replace(json.original_url);
        }
      } catch (err) {
        showMessage("Network error. Please try again.", "text-red-500");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Submit";
      }


    }
    function showMessage(text, colorClass) {
      const p = document.createElement("p");
      p.textContent = text;
      p.className = `${colorClass} text-xs font-medium`;
      messageBox.appendChild(p);
    }

  </script>
</body>

</html>