<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        /* Basic reset for email clients */
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }

        .wrapper {
            width: 100%;
            table-layout: fixed;
            background-color: #f4f4f4;
            padding-bottom: 40px;
        }

        .main-table {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 8px;
            overflow: hidden;
            margin-top: 40px;
            border-collapse: collapse;
        }

        .content {
            padding: 40px 30px;
            color: #333333;
            line-height: 1.6;
        }

        .button-container {
            padding: 20px 0;
            text-align: center;
        }

        .button {
            background-color: #007bff;
            color: #ffffff !important;
            padding: 14px 24px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            display: inline-block;
        }

        .footer {
            text-align: center;
            font-size: 12px;
            color: #888888;
            padding: 20px;
        }

        /* Mobile adjustment */
        @media screen and (max-width: 600px) {
            .main-table {
                width: 95% !important;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <table class="main-table">
            <!-- Header/Logo -->
            <tr>
                <td style="padding: 30px; text-align: center; background-color: #1a1a1a;">
                    <h1 style="color: #ffffff; margin: 0; font-size: 24px;">ZipUrl</h1>
                </td>
            </tr>
            <!-- Body -->
            <tr>
                <td class="content">
                    <h2 style="margin-top: 0;">Password Reset Request</h2>
                    <p>Hi {{name}},</p>
                    <p>We received a request to reset the password for your account. If you made this request, please
                        click the button below to set a new password:</p>

                    <div class="button-container">
                        <a href="{{reset_link}}" class="button">Reset My Password</a>
                    </div>

                    <p><strong>Note:</strong> This link will expire in 60 minutes. If you did not request a password
                        reset, you can safely ignore this email.</p>
                    <p>For security, never share this link with anyone else.</p>
                </td>
            </tr>
            <!-- Footer -->
            <tr>
                <td class="footer">
                    &copy; 2026 ZipUrl, Inc. <br>
                    123 Tech Lane, Silicon Valley, CA <br>
                    <a href="#" style="color: #888888;">Privacy Policy</a> | <a href="#"
                        style="color: #888888;">Support</a>
                </td>
            </tr>
        </table>
    </div>
</body>

</html>