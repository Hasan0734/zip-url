<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        /* Basic reset for email clients */
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }

        .wrapper {
            width: 100%;
            table-layout: fixed;
            background-color: #f4f4f4;
            padding-bottom: 40px;
        }

        .main-table {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 8px;
            overflow: hidden;
            margin-top: 40px;
            border-collapse: collapse;
        }

        .content {
            padding: 40px 30px;
            color: #333333;
            line-height: 1.6;
        }

        .status-icon {
            text-align: center;
            padding: 20px 0 0 0;
            font-size: 48px;
        }

        .footer {
            text-align: center;
            font-size: 12px;
            color: #888888;
            padding: 20px;
        }

        /* Mobile adjustment */
        @media screen and (max-width: 600px) {
            .main-table {
                width: 95% !important;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <table class="main-table">
            <!-- Header/Logo -->
            <tr>
                <td style="padding: 30px; text-align: center; background-color: #1a1a1a;">
                    <h1 style="color: #ffffff; margin: 0; font-size: 24px;">ZipUrl</h1>
                </td>
            </tr>
            <!-- Body -->
            <tr>
                <td class="content">
                    <div class="status-icon">✅</div>
                    <h2 style="margin-top: 10px; text-align: center;">Your password was changed</h2>
                    <p>Hi {{name}},</p>
                    <p>This is a confirmation that the password for your <strong>ZipUrl</strong> account has been
                        successfully changed.</p>

                    <p style="background-color: #fff9db; padding: 15px; border-left: 4px solid #fcc419;">
                        <strong>Didn't make this change?</strong><br>
                        If you did not change your password, please secure your account immediately by clicking here:
                        <br>
                        <a href="{{secure_account_link}}" style="color: #007bff; font-weight: bold;">Secure My
                            Account</a>
                    </p>

                    <p>If this was you, you can safely disregard this email. No further action is required.</p>
                    <p>Stay safe,<br>The ZipUrl Team</p>
                </td>
            </tr>
            <!-- Footer -->
            <tr>
                <td class="footer">
                    &copy; 2026 ZipUrl, Inc. <br>
                    123 Tech Lane, Silicon Valley, CA <br>
                    <a href="#" style="color: #888888;">Privacy Policy</a> | <a href="#"
                        style="color: #888888;">Support</a>
                </td>
            </tr>
        </table>
    </div>
</body>

</html>